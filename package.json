{
  "name": "@olduvai-jp/codex-browser",
  "version": "0.1.1",
  "description": "Browser UI for Codex with a built-in bridge server.",
  "type": "module",
  "bin": {
    "codex-browser": "./bin/codex-browser.js"
  },
  "files": [
    "bin",
    "dist",
    "server/*.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "cross-env CODEX_BROWSER_DEV=1 node bin/codex-browser.js",
    "dev:frontend": "vite",
    "dev:backend": "tsx server/bridge.ts",
    "dev:all": "run-p dev:frontend dev:backend",
    "bridge": "tsx server/bridge.ts",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:screenshot": "cross-env PW_SCREENSHOT_MODE=on playwright test",
    "test:e2e:screenshot:fail": "cross-env PW_SCREENSHOT_MODE=only-on-failure playwright test",
    "test:e2e:screenshot:off": "cross-env PW_SCREENSHOT_MODE=off playwright test",
    "build-only": "vite build",
    "prepack": "npm run build-only",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "tsx": "^4.21.0",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-oxlint": "~1.46.0",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.47.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
